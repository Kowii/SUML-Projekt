# =====================================================================
# OrnithoAI - Bird Species Classifier Environment Template
# =====================================================================

# Configurable directory and file names for the PyTorch weights & class mappings.
# Shared via Docker volumes between the trainer and backend services.
MODEL_DIR=/models
MODEL_FILE=bird_classifier.pt
CLASSES_FILE=classes.json

# PyTorch/TIMM Model architecture. Highly modular and replaceable 
# without altering API routes or frontend models (e.g., resnet50, efficientnet_b0, convnext_tiny)
MODEL_NAME=resnet50

# URL used by Streamlit frontend to access the FastAPI backend REST API
BACKEND_URL=http://localhost:8000
