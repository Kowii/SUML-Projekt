# =====================================================================
# OrnithoAI - Bird Species Classifier Environment Template
# =====================================================================

# Paths for model weights and class mapping (shared between trainer and backend)
MODEL_DIR=/models
MODEL_FILE=bird_classifier.pt
CLASSES_FILE=classes.json

# Torchvision model architecture — resnet18 (default) or resnet50
MODEL_NAME=resnet18

# Training hyperparameters (used by the trainer service)
BATCH_SIZE=32
NUM_EPOCHS=5
LEARNING_RATE=1e-3

# URL used by Streamlit frontend to reach the FastAPI backend
BACKEND_URL=http://localhost:8000
